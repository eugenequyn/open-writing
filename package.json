{
  "name": "ow-cli",
  "version": "0.1.0",
  "description": "Open Writing CLI - 配置驱动的写作项目管理工具",
  "type": "module",
  "bin": {
    "ow": "./dist/bin/ow.js"
  },
  "scripts": {
    "build": "tsc && npm run copy:assets",
    "copy:assets": "npx cpy \"src/**/*.yaml\" \"dist/\" && npx cpy \"src/**/*.hbs\" \"dist/\" && npx cpy \"src/**/*.handlebars\" \"dist/\" && npx cpy \"src/**/*.md\" \"dist/\"",
    "dev": "tsx bin/ow.ts",
    "start": "node dist/cli.js",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "writing",
    "novel",
    "cli",
    "ai-assisted"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "zod": "^3.23.8",
    "js-yaml": "^4.1.0",
    "handlebars": "^4.7.8",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "glob": "^10.3.12",
    "hasha": "^6.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "@types/node": "^20.12.7",
    "@types/js-yaml": "^4.0.9",
    "@types/handlebars": "^4.1.0",
    "tsx": "^4.9.0",
    "cpy-cli": "^5.0.0"
  }
}
